{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd apps/api && npm install && npm run build",
    "watchPatterns": ["apps/api/**"]
  },
  "deploy": {
    "startCommand": "cd apps/api && npm run start:prod",
    "healthcheckPath": "/api/v1/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
